  "reductionRules": {
    "method1_digitSum": {
      "name": "Sum all digits until single digit",
      "description": "Add all digits of a number until you get a single digit (1-9)",
      "examples": {
        "25": "2+5=7",
        "156": "1+5+6=12, 1+2=3",
        "33": "3+3=6"
      }
    },
    "method2_modulo": {
      "name": "Modulo 9 (cycling 1-9)",
      "description": "Use letter position modulo 9, where 0 becomes 9",
      "formula": "if n mod 9 = 0 then 9, else n mod 9"
    },
    "masterNumbers": {
      "description": "Some sources keep 11, 22, 33 as special master numbers",
      "values": [11, 22, 33],
      "status": "OPTIONAL - verify in next book sections"
    }
  },

