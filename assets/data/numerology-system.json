  "calculators": {
    "birthDate": {
      "id": "birthDate",
      "title": "Расчет по дате рождения",
      "description": "Личный код человека по дате рождения",
      "priority": "CRITICAL",
      "phase": 1,
      "enabled": true,
      "inputs": {
        "day": {
          "type": "number",
          "min": 1,
          "max": 31,
          "required": true,
          "label": "День"
        },
        "month": {
          "type": "number",
          "min": 1,
          "max": 12,
          "required": true,
          "label": "Месяц"
        },
        "year": {
          "type": "number",
          "min": 1900,
          "max": 2100,
          "required": true,
          "label": "Год"
        }
      },
      "formula": {
        "description": "Sum all digits of day + month + year, then reduce to 1-9",
        "source": "Глава 9: Просчеты по дате рождения (стр. 69)",
        "example": "11.09.2012 → sum digits → 17 → reduce → 8",
        "steps": [
          "Sum all digits: (1+1)+(0+9)+(2+0+1+2) = 16 or 17",
          "Reduce to single digit: if > 9, sum digits again"
        ]
      },
      "outputs": {
        "primary": "Two-digit code or single digit (1-9)",
        "secondary": "Reduced single digit",
        "interpretation": "Mystical meaning from Table 3"
      },
      "confidenceLevel": "HIGH",
      "notes": "Example in book shows 11.09.2012 = 17 = 8"
    },

    "fullName": {
      "id": "fullName",
      "title": "Расчет по ФИО (Фамилия, Имя, Отчество)",
      "description": "Числовой код личности по полному имени",
      "priority": "CRITICAL",
      "phase": 1,
      "enabled": true,
      "inputs": {
        "surname": {
          "type": "text",
          "required": true,
          "label": "Фамилия",
          "placeholder": "Глебова"
        },
        "name": {
          "type": "text",
          "required": true,
          "label": "Имя",
          "placeholder": "Сергей"
        },
        "patronymic": {
          "type": "text",
          "required": false,
          "label": "Отчество",
          "placeholder": "Николаевич"
        }
      },
      "formula": {
        "description": "Convert each letter to number using alphabet table, sum, reduce to code",
        "source": "Глава 2: Русский алфавит (Таблица №1)",
        "examples": [
          "Глебова = 4,16,6,2,16,3,1 = (sum) = (reduce)",
          "Дмитрий Донской = 5,5,12,9,12,12,9 = 5,7,6,1,3,7,2 (parts)",
          "Михаил Кутузов = 5,15,11,4 = (calculate)"
        ]
      },
      "outputs": {
        "primary": "Numeric code (can be double digit or single)",
        "secondary": "Reduced single digit (1-9)",
        "interpretation": "Personality code from Table 3"
      },
      "confidenceLevel": "HIGH",
      "notes": "Each letter uses alphabet mapping. Spaces ignored."
    },

