# OpenAI API Configuration
# Получить ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx

# ============================================================
# PayKeeper / Alfa-Bank Internet Acquiring
# Данные из письма "PayKeeper - доступ в личный кабинет"
# ============================================================

# Адрес вашего сервера PayKeeper (только хост, без https:// и без слэша)
# Тестовый сервер: tsiframir.server.paykeeper.ru
# Продакшн сервер: указывается PayKeeper при переходе в боевой режим
PAYKEEPER_SERVER_URL=tsiframir.server.paykeeper.ru

# Секретное слово для проверки подписи POST-оповещений
# Берётся из Личного кабинета PayKeeper → Настройки → Получение информации о платежах → POST-оповещения
# НИКОГДА не коммитить это значение в git!
PAYKEEPER_SECRET=your_secret_word_here

# URL сайта — используется для формирования адреса возврата после оплаты
SITE_URL=https://tsiframir.ru

# Опционально: для локального развития
NODE_ENV=development
